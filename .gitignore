# ── Android ───────────────────────────────────────────────────
# CRITICAL: local.properties contains machine-specific SDK/Flutter paths
# Codemagic generates this automatically — never commit it
android/local.properties
android/.gradle/
android/captures/
android/gradlew        
android/gradlew.bat    

# Keep gradle wrapper JAR and properties (required by Codemagic)
!android/gradle/wrapper/gradle-wrapper.jar
!android/gradle/wrapper/gradle-wrapper.properties

